{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "tommy-stabssoftware",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
